<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    TestNG Suite Configuration
    Parallel execution: thread-count controls concurrent scenarios
    Run: mvn clean test
    Run smoke only: mvn clean test -Dcucumber.filter.tags="@smoke"
-->
<suite name="Payroll Automation Suite"
       verbose="1"
       parallel="methods"
       thread-count="3"
       data-provider-thread-count="3">

    <listeners>
        <listener class-name="listeners.TestNGListener"/>
    </listeners>

    <test name="Payroll Tests">
        <classes>
            <class name="runner.TestRunner"/>
        </classes>
    </test>

</suite>
